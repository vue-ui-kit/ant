{
  "name": "@vue-ui-kit/ant",
  "version": "2.4.6",
  "description": "Vue3 UI Kit based on Ant Design",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/es/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/style.css",
  "sass": "./dist/style.scss",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/es/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./style.scss": "./src/packages/styles/index.scss",
    "./dist/style.scss": "./dist/style.scss",
    "./dist/style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "README.zh.md",
    "tsconfig.json"
  ],
  "scripts": {
    "dev": "vue-tsc --noEmit --skipLibCheck & vite",
    "build": "ts-patch install && vite build && sass src/packages/styles/index.scss dist/style.css --no-source-map",
    "prepack": "rimraf dist && pnpm build",
    "prepare": "husky",
    "lint:lint-staged": "lint-staged",
    "lint:prettier": "prettier --write  \"src/**/*.{js,json,tsx,css,less,scss,vue,html,md}\""
  },
  "keywords": [
    "vue3",
    "ui kit",
    "ant design",
    "ant",
    "antdv"
  ],
  "author": {
    "name": "adoin",
    "email": "adoin@qq.com"
  },
  "dependencies": {
    "e-virt-table": "^1.3.17",
    "uuid": "^10.0.0",
    "xe-utils": "^3.7.6"
  },
  "peerDependencies": {
    "@ant-design/icons-vue": ">=7.0.0",
    "ant-design-vue": ">=4.0.0",
    "vue": ">=3.2.0"
  },
  "license": "GPL",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "devDependencies": {
    "@ant-design/icons-vue": ">=7.0.0",
    "@commitlint/cli": "^19.4.1",
    "@commitlint/config-conventional": "^19.4.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "ant-design-vue": "^4.2.3",
    "esbuild": "^0.28.0",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "sass": "^1.77.8",
    "ts-patch": "^3.2.1",
    "typescript-transform-paths": "^3.5.0",
    "vite": "^8.0.8",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.4.38"
  }
}
